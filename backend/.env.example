# Copy this file to backend/.env for local, non-Docker development.
# On Render, set the same variables in the service environment instead of
# uploading a .env file.

DATABASE_URL=postgres://<user>:<password>@<host>:<port>/<database>?sslmode=require
JWT_SECRET=<replace-with-a-long-random-secret>
# Local frontend origin. In Render, set this to your deployed frontend URL.
FRONTEND_URL=http://localhost:4200
# Local fallback. Render injects PORT automatically.
PORT=3000

# Optional payment configuration
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_test_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
RAZORPAY_CHECKOUT_NAME=GrabAPass
