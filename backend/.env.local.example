# Copy this file to backend/.env when running the backend directly on your laptop
# against a locally installed PostgreSQL instance.

DATABASE_URL=postgres://postgres:password@localhost:5432/grabapass
JWT_SECRET=replace-with-a-long-random-secret
FRONTEND_URL=http://localhost:4200
PORT=3000

# Optional payment configuration
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_test_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
RAZORPAY_CHECKOUT_NAME=GrabAPass
